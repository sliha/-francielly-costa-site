rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ───────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isVideo() {
      return request.resource.contentType.matches('video/.*');
    }

    function isImageOrVideo() {
      return isImage() || isVideo();
    }

    // ── Galeria / Media por serviço ───────────────────────────────────────────
    // Admin upload only; public read
    match /galeria/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isImageOrVideo()
        && request.resource.size < 200 * 1024 * 1024; // 200 MB max
    }

    match /media/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isImageOrVideo()
        && request.resource.size < 200 * 1024 * 1024;
    }

    // ── Fotos pessoais / Configurações ────────────────────────────────────────
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated() && isImage()
        && request.resource.size < 5 * 1024 * 1024; // 5 MB max
    }

    // ── Anything else: deny by default ───────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
