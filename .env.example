# ─────────────────────────────────────────────────────────────
# Site Francielly Costa — variáveis de ambiente
# Stack: Next.js 14 (App Router) · Supabase · Stripe · Resend ·
#        Google Calendar · Anthropic · (opcional) Gemini
# ─────────────────────────────────────────────────────────────

# Supabase (base de dados, auth, storage)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...            # chave pública (anon)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...                # SECRETA — só no servidor

# Site
NEXT_PUBLIC_BASE_URL=https://franciellycosta.pt
NEXT_PUBLIC_WHATSAPP_LINK=https://wa.link/kwctpf

# Stripe (caução de marcação)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxxx
STRIPE_SECRET_KEY=sk_live_or_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Resend (emails transacionais)
RESEND_API_KEY=re_xxxx
ADMIN_EMAIL=geral@franciellycosta.pt                   # destinatário das notificações
ADMIN_EMAILS=email1@dominio.com,email2@dominio.com     # emails com acesso admin

# Anthropic (assistente Sofia + simulador de resultados)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Gemini (opcional — simulador alternativo)
GEMINI_API_KEY=your_gemini_api_key

# Google Calendar (sincronização da agenda)
GOOGLE_CALENDAR_ID=xxxx@gmail.com
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}   # JSON da service account (uma linha)

# Cron jobs (Vercel) — protege os endpoints agendados
CRON_SECRET=uma_string_aleatoria_longa

# Analytics (públicas)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=000000000000000
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-000000000
