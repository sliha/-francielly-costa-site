# Copia para .env e preenche. NUNCA commitar o .env.

# ── PROJECTO GCP ──────────────────────────────────────────────────────────────
# (pode ser o mesmo projecto do Biogé se tiveres Vertex AI ativo)
GCP_PROJECT_ID="bioge-ai-generation"

# ── IMAGENS (Imagen 3) ────────────────────────────────────────────────────────
GCP_LOCATION_IMAGE="us-central1"
FC_IMAGE_MODEL="imagen-3.0-generate-001"

# Aspect ratio padrão: 1:1 | 9:16 | 16:9
FC_ASPECT_RATIO="1:1"

# ── CREDENCIAIS ───────────────────────────────────────────────────────────────
# A mesma service account do Biogé funciona (papel "Vertex AI User").
# Aponta para o ficheiro JSON FORA do repositório.
GOOGLE_APPLICATION_CREDENTIALS="C:/Users/malta/.config/bioge/credentials.json"

# ── RETRY ─────────────────────────────────────────────────────────────────────
FC_RETRY_429_SECS=60
FC_MAX_TRIES=6
